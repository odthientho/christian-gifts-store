PORT=4000
DATABASE_URL="postgresql://cgs:cgs_local_dev@localhost:5433/christian_gifts_store?schema=public"
# Storefront (3000) and admin (3001) origins allowed to call the API.
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

JWT_SECRET="replace-with-openssl-rand-base64-32"

# Online payment is off for now — orders are placed directly and an admin
# collects payment and confirms it manually (see PENDING orders in the admin
# dashboard). Flip to "true" once ready to take real payment; Stripe stays
# fully wired up either way.
PAYMENTS_ENABLED="false"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
