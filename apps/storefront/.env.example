# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# --- Database -------------------------------------------------------------
# Matches docker-compose.yml. Host port is 5433 to avoid clashing with any
# Postgres already listening on 5432.
DATABASE_URL="postgresql://cgs:cgs_local_dev@localhost:5433/christian_gifts_store?schema=public"

# --- Auth.js --------------------------------------------------------------
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Base URL of the app. Required in production.
AUTH_URL="http://localhost:3000"

# --- Stripe ---------------------------------------------------------------
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# From: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Seeded admin account (used by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

API_URL="http://localhost:4000/api"
