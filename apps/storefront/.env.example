# The storefront is a pure API consumer — no database, no auth, no Stripe here.
API_URL="http://localhost:4000/api"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Public base URL for the API — used client-side (<img> tags pointing at
# uploaded images) since the browser cannot use the server-only API_URL.
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
