{
  "name": "gin-store",
  "version": "0.1.0",
  "private": true,
  "description": "GIN Store — headless Christian gifts & books commerce (API + storefront + admin)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "npm run generate -w @gin/db",
    "db:migrate": "npm run migrate -w @gin/db",
    "db:seed": "npm run seed -w @gin/db",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.9"
  }
}
